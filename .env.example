# Copy this file to .env and adjust for your environment.
# The app runs fine with NONE of these set (SQLite + dev secret).

# --- Database ---
# Default is local SQLite. To use PostgreSQL, uncomment and edit:
# DATABASE_URL=postgresql://username:password@localhost:5432/students
# For MySQL: DATABASE_URL=mysql+pymysql://username:password@localhost:3306/students

# --- Auth ---
# REQUIRED in production. Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ACCESS_TOKEN_HOURS=1

# --- Server ---
# Set to 1 only for local debugging. NEVER enable in production.
FLASK_DEBUG=0
